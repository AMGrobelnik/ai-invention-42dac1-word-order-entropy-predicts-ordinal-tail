\citation{Maxwell2007}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Mediation analysis of the morphological richness $\rightarrow $ word-order entropy $\rightarrow $ $\xi $ pathway (Preacher--Hayes bootstrap, 5,000 resamples). The indirect path ($a \times b = 0.029$) is significant, but the direct path ($c' = -0.026$) opposes it, yielding a near-zero total effect ($c = 0.002$). The opposing paths represent a classical suppression pattern; cross-sectional mediation cannot establish causal ordering \cite  {Maxwell2007}. Solid arrows indicate significant paths; dashed arrows indicate non-significant paths.}}{14}{figure.5}\protected@file@percent }
\newlabel{fig:mediation}{{5}{14}{Mediation analysis of the morphological richness $\rightarrow $ word-order entropy $\rightarrow $ $\xi $ pathway (Preacher--Hayes bootstrap, 5,000 resamples). The indirect path ($a \times b = 0.029$) is significant, but the direct path ($c' = -0.026$) opposes it, yielding a near-zero total effect ($c = 0.002$). The opposing paths represent a classical suppression pattern; cross-sectional mediation cannot establish causal ordering \cite {Maxwell2007}. Solid arrows indicate significant paths; dashed arrows indicate non-significant paths}{figure.5}{}}

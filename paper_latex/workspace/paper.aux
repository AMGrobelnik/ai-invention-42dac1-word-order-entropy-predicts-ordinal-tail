\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Scatter plot of treebank-level word-order entropy \cite  {Levshina2019} against GEV shape parameter $\xi $ for 172 treebanks in the regression sample. The regression line (solid) shows the positive association ($\beta = 0.084$, $p_{\text  {FDR}} = 0.0007$, partial $r = 0.246$). Six key languages are annotated. Languages with freer word order (higher entropy) show softer tail constraints (less negative $\xi $). The shaded band indicates the 95\% confidence region. Note: this association vanishes when restricted to GEV fits passing absolute goodness-of-fit ($p = 0.93$; see Section\nobreakspace  {}\ref {sec:sensitivity}).}}{12}{figure.4}\protected@file@percent }
\newlabel{fig:entropy_xi}{{4}{12}{Scatter plot of treebank-level word-order entropy \cite {Levshina2019} against GEV shape parameter $\xi $ for 172 treebanks in the regression sample. The regression line (solid) shows the positive association ($\beta = 0.084$, $p_{\text {FDR}} = 0.0007$, partial $r = 0.246$). Six key languages are annotated. Languages with freer word order (higher entropy) show softer tail constraints (less negative $\xi $). The shaded band indicates the 95\% confidence region. Note: this association vanishes when restricted to GEV fits passing absolute goodness-of-fit ($p = 0.93$; see Section~\ref {sec:sensitivity})}{figure.4}{}}
